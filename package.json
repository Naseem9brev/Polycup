{
  "name": "polycup",
  "version": "1.0.0",
  "description": "Dependency-free Node.js CLI that predicts the 2026 FIFA World Cup via Elo + Dixon-Coles/Poisson + Monte Carlo.",
  "main": "polycup.js",
  "bin": {
    "polycup": "polycup.js"
  },
  "files": [
    "*.js",
    "scripts/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "start": "node polycup.js",
    "build:binary": "node scripts/build-binary.js",
    "verify:playerxg": "node verify-playerxg.js",
    "verify:penalty": "node verify-penalty.js",
    "verify:matchxg": "node verify-matchxg.js"
  },
  "keywords": [
    "world-cup",
    "2026",
    "fifa",
    "elo",
    "poisson",
    "dixon-coles",
    "monte-carlo",
    "soccer",
    "football",
    "prediction",
    "cli",
    "dependency-free"
  ],
  "author": "Avi (https://github.com/avikabra)",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Naseem9brev/Polycup.git"
  },
  "bugs": {
    "url": "https://github.com/Naseem9brev/Polycup/issues"
  },
  "homepage": "https://github.com/Naseem9brev/Polycup#readme"
}
